#!/usr/bin/env bash

WALLPAPER_DIR="${1:-$HOME/.config/wallpapers}"
ROFI_THEME="$HOME/.config/rofi/launcher/style.rasi"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wall-picker/thumbnails"
THUMB_SIZE="400x400"

mkdir -p "$CACHE_DIR"

mapfile -t IMG_FILES < <(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" -o -iname "*.webp" \))

if [ "${#IMG_FILES[@]}" -eq 0 ]; then
    notify-send "wall-picker" "No images found in $WALLPAPER_DIR"
    exit 1
fi

ROFI_INPUT=""
for IMG_FILE in "${IMG_FILES[@]}"; do
    BASENAME=$(basename "$IMG_FILE")
    NAME_WITHOUT_EXT="${BASENAME%.*}"
    EXTENSION="${BASENAME##*.}"

    if [ ${#NAME_WITHOUT_EXT} -gt 22 ]; then
        DISPLAY_NAME="${NAME_WITHOUT_EXT:0:19}....${EXTENSION}"
    else
        DISPLAY_NAME="${NAME_WITHOUT_EXT}.${EXTENSION}"
    fi

    THUMB_FILE="$CACHE_DIR/${BASENAME}.png"
    if [ ! -f "$THUMB_FILE" ]; then
        convert "$IMG_FILE" -auto-orient -thumbnail "${THUMB_SIZE}^" -gravity center -extent "$THUMB_SIZE" "$THUMB_FILE"
    fi
    ROFI_INPUT+="${DISPLAY_NAME}\0icon\x1f${THUMB_FILE}\0info\x1f${IMG_FILE}\n"
done

SELECTED_INDEX=$(echo -en "$ROFI_INPUT" | rofi -dmenu \
    -show-icons \
    -theme "$ROFI_THEME" \
    -p "Select Wallpaper" \
    -format 'i' \
    -selected-row 0
)

[ -z "$SELECTED_INDEX" ] && exit 0

WALLPAPER_PATH="${IMG_FILES[$SELECTED_INDEX]}"

if [ ! -f "$WALLPAPER_PATH" ]; then
    notify-send "wall-picker" "Error: file '$WALLPAPER_PATH' not found"
    exit 1
fi

awesome-client "wall_picker_set('$WALLPAPER_DIR', '$WALLPAPER_PATH')"
